# Legacy combined local env file.
# Preferred setup: use `.env.tunnel` + `.env.install` instead.

SSH_TARGET=<ssh_user@vps_host>
SSH_KEY_PATH=<path_to_private_key>
PUBLIC_HOST=<public_https_host>
TUNNEL_UPSTREAM_HOST=127.0.0.1
REMOTE_TUNNEL_BIND_ADDRESS=127.0.0.1
REMOTE_FRONTEND_INTERNAL_PORT=45173
REMOTE_BACKEND_INTERNAL_PORT=43000
GOOGLE_CLIENT_ID=<google_client_id>
GOOGLE_CLIENT_SECRET=<google_client_secret>
GOOGLE_REDIRECT_URI=https://<public_https_host>/api/google_oauth2

# If PUBLIC_HOST and SSH_TARGET are different servers:
# - run install-remote-caddy.sh on PUBLIC_HOST server with TUNNEL_UPSTREAM_HOST=<SSH_TARGET host>
# - run run-dev-tunnel.sh against SSH_TARGET with REMOTE_TUNNEL_BIND_ADDRESS=0.0.0.0
# - ensure sshd on SSH_TARGET has: GatewayPorts clientspecified

# Optional production deploy overrides
DEPLOY_SSH_TARGET=<ssh_user@prod_vps_host>
DEPLOY_PUBLIC_HOST=<production_public_host>
DEPLOY_REMOTE_DIR=/opt/qstream
DEPLOY_SYSTEM_USER=qstream
DEPLOY_BACKEND_PORT=3000
DEPLOY_DATABASE_URL=sqlite:///var/lib/qstream/qstream.db?mode=rwc
