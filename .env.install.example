DEPLOY_SSH_TARGET=<ssh_user@production_host>
DEPLOY_PUBLIC_HOST=<production_public_host>
DEPLOY_SSH_KEY_PATH=<path_to_private_key>
DEPLOY_GOOGLE_CLIENT_ID=<google_client_id>
DEPLOY_GOOGLE_CLIENT_SECRET=<google_client_secret>
DEPLOY_GOOGLE_REDIRECT_URI=https://<production_public_host>/api/google_oauth2
DEPLOY_DA_CLIENT_ID=<donationalerts_client_id>
DEPLOY_DA_CLIENT_SECRET=<donationalerts_client_secret>
DEPLOY_DA_REDIRECT_URI=https://<production_public_host>/api/da/oauth/callback

# Optional production deploy overrides
DEPLOY_REMOTE_DIR=/opt/qstream
DEPLOY_SYSTEM_USER=qstream
DEPLOY_BACKEND_PORT=3000
DEPLOY_DATABASE_URL=sqlite:///var/lib/qstream/qstream.db?mode=rwc
DEPLOY_RUST_TARGET=x86_64-unknown-linux-musl
